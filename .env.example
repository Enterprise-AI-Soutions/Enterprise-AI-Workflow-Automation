# ──────────────────────────────────────────────────────────────────────────────
# Enterprise AI Workflow Automation — Environment Variables
# Copy this file to .env and fill in your values.
# ──────────────────────────────────────────────────────────────────────────────

# ── App ───────────────────────────────────────────────────────────────────────
APP_NAME="Enterprise AI Workflow Automation"
APP_VERSION="1.0.0"
APP_ENV=development          # development | staging | production
DEBUG=true
SECRET_KEY=changeme-generate-a-long-random-string-here
ALLOWED_ORIGINS=["*"]

# ── Server ────────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000

# ── Database ──────────────────────────────────────────────────────────────────
# SQLite (default, zero-config for local dev)
DATABASE_URL=sqlite+aiosqlite:///./enterprise_ai.db

# PostgreSQL (for production / Docker)
# DATABASE_URL=postgresql+asyncpg://postgres:secret@localhost:5432/enterprise_ai

# ── Anthropic / Claude AI ─────────────────────────────────────────────────────
# Get your key at: https://console.anthropic.com
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-3-5-sonnet-20241022
CLAUDE_MAX_TOKENS=4096

# ── Google Workspace ──────────────────────────────────────────────────────────
# Setup: https://console.cloud.google.com → APIs & Services → Credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/auth/google/callback
GOOGLE_CREDENTIALS_FILE=credentials.json
GOOGLE_TOKEN_FILE=token.json

# ── Airtable ──────────────────────────────────────────────────────────────────
# Get your key at: https://airtable.com/account
AIRTABLE_API_KEY=
AIRTABLE_BASE_ID=

# ── n8n ───────────────────────────────────────────────────────────────────────
N8N_BASE_URL=http://localhost:5678
N8N_API_KEY=
N8N_WEBHOOK_URL=

# ── Redis (optional) ──────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Docker / PostgreSQL ───────────────────────────────────────────────────────
POSTGRES_PASSWORD=secret
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=changeme

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FORMAT=text              # text | json
