# ──────────────────────────────────────────────────────────────────────────────
# Enterprise AI Workflow Automation — Environment Variables
# Copy this file to .env and fill in your values.
# The app runs fully in demo mode if API keys are left blank.
# ──────────────────────────────────────────────────────────────────────────────

# ── App ───────────────────────────────────────────────────────────────────────
APP_NAME="Enterprise AI Workflow Automation"
APP_VERSION="1.0.0"
APP_ENV=development          # development | staging | production
DEBUG=true
SECRET_KEY=changeme-generate-a-long-random-string-here
ALLOWED_ORIGINS=["*"]        # Production: ["https://yourdomain.com"]

# ── Server ────────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000

# ── Database ──────────────────────────────────────────────────────────────────
# SQLite — zero-config, ideal for local development
DATABASE_URL=sqlite+aiosqlite:///./enterprise_ai.db

# PostgreSQL — for production or Docker Compose
# DATABASE_URL=postgresql+asyncpg://postgres:secret@localhost:5432/enterprise_ai

# ── Anthropic / Claude AI ─────────────────────────────────────────────────────
# Get your key: https://console.anthropic.com
# Leave blank to run in demo mode (returns realistic mock responses)
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-3-5-sonnet-20241022
CLAUDE_MAX_TOKENS=4096

# ── Google Workspace (Gmail · Calendar · Drive · Sheets) ──────────────────────
# Setup guide: https://console.cloud.google.com → APIs & Services → Credentials
# Enable APIs: Gmail API, Google Calendar API, Google Drive API, Google Sheets API
# Leave blank to run all Google integrations in demo mode
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/auth/google/callback
GOOGLE_CREDENTIALS_FILE=credentials.json   # OAuth2 client secrets file
GOOGLE_TOKEN_FILE=token.json               # Auto-generated after first auth

# ── Google Apps Script ────────────────────────────────────────────────────────
# Set this in Apps Script editor → Project Settings → Script Properties
# (not needed in the FastAPI .env — documented here for reference)
# APPS_SCRIPT_API_BASE_URL=https://your-domain.com/api/v1

# ── Airtable ──────────────────────────────────────────────────────────────────
# Get your key: https://airtable.com/account → API
# Leave blank to run in demo mode
AIRTABLE_API_KEY=
AIRTABLE_BASE_ID=           # e.g. appXXXXXXXXXXXXXX

# ── n8n Workflow Engine ───────────────────────────────────────────────────────
# Default for local/Docker; update if deployed elsewhere
N8N_BASE_URL=http://localhost:5678
N8N_API_KEY=                # n8n Settings → API → Create API Key
N8N_WEBHOOK_URL=            # Optional: public URL for webhook callbacks (e.g. ngrok)

# ── Redis (optional — for caching / rate limiting) ────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Docker / PostgreSQL ───────────────────────────────────────────────────────
POSTGRES_PASSWORD=secret
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=changeme   # Change before deploying publicly

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO               # DEBUG | INFO | WARNING | ERROR
LOG_FORMAT=text              # text | json
